<!DOCTYPE html>
<html>
<head>
  <title>Sweet Bakery</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  
  <style>
    body {
      font-family: Arial;
      margin: 0;
      background: #fff8f0;
    }

    header {
      background: #ff6f61;
      color: white;
      padding: 20px;
      text-align: center;
    }

    nav {
      background: #333;
      padding: 10px;
      text-align: center;
    }

    nav a {
      color: white;
      margin: 10px;
      text-decoration: none;
      font-weight: bold;
    }

    .hero {
      background: url('https://images.unsplash.com/photo-1559620192-032c4bc4674e');
      background-size: cover;
      color: white;
      padding: 60px 20px;
      text-align: center;
    }

    section {
      padding: 20px;
    }

    .card {
      background: white;
      padding: 15px;
      margin: 10px 0;
      border-radius: 10px;
      box-shadow: 0 0 10px #ccc;
    }

    .menu {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
      gap: 10px;
    }

    .btn {
      background: #25D366;
      color: white;
      padding: 10px;
      text-decoration: none;
      border-radius: 5px;
      display: inline-block;
    }

    footer {
      background: #333;
      color: white;
      text-align: center;
      padding: 15px;
    }
  </style>
</head>

<body>

<header>
  <h1>🍰 Sweet Bakery</h1>
  <p>Fresh Cakes • Bread • Cookies</p>
</header>

<nav>
  <a href="#">Home</a>
  <a href="#">Menu</a>
  <a href="#">Contact</a>
</nav>

<div class="hero">
  <h2>Delicious Cakes Made Fresh Daily 🎂</h2>
  <p>Order your favorite sweets today!</p>
</div>

<section>
  <div class="card">
    <h2>About Us</h2>
    <p>We bake fresh and tasty cakes, breads, and snacks every day with love ❤️</p>
  </div>

  <div class="card">
    <h2>Our Menu</h2>
    <div class="menu">
      <p>🎂 Birthday Cakes</p>
      <p>🍞 Fresh Bread</p>
      <p>🧁 Cupcakes</p>
      <p>🍪 Cookies</p>
    </div>
  </div>

  <div class="card">
    <h2>Contact</h2>
    <p>📞 Phone: 9876543210</p>
    <a class="btn" href="https://wa.me/919876543210">Order on WhatsApp</a>
  </div>
</section>

<footer>
  <p>© 2026 Sweet Bakery | All Rights Reserved</p>
</footer>

</body>
</html>
